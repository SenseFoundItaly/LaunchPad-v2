# LLM API Keys (at least one required)
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Pi Agent SDK — provider + model selection for runAgent()/runAgentStream()
# When a route passes a `task` label to runAgent(), the router in
# src/lib/llm/router.ts picks the tier automatically and these env vars are
# ignored. They remain as a fallback for call sites that haven't been
# retrofitted yet.
# PI_PROVIDER=anthropic        # anthropic | openai
# PI_MODEL=claude-sonnet-4-20250514

# Task-complexity routing override — optional JSON mapping of task → tier.
# Overrides the defaults in src/lib/llm/router.ts. Useful to temporarily
# force "chat" to premium for user testing, or "monitor-agent" to cheap to
# slash cost after Forge-scale ramp. Tiers: cheap | balanced | premium.
# LLM_ROUTING_JSON={"chat":"premium","monitor-agent":"cheap"}

# Pi Agent prompt caching — ephemeral cache TTL on the Anthropic system prompt
# and last-user-message. Pi AI defaults to "short" (5 min TTL). "long" (1 h TTL)
# is worth it for the Monday cron run where 4 ecosystem monitors execute
# back-to-back against the same stable SOUL+AGENTS+HEARTBEAT prefix.
# Confirm caching is working via `llm_usage_logs.cache_read_tokens > 0`.
PI_CACHE_RETENTION=long

# Optional: Langfuse LLM Observability
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Supabase Auth (required for login)
# Create a project at https://supabase.com, enable "Email" provider with magic link,
# then paste the keys from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Only needed for server-side admin operations (we don't use it today; reserved for later):
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Dev-only: which email the backfill script attaches existing projects to.
DEV_USER_EMAIL=dev@launchpad.local

# Monday Brief email (optional). When unset, src/lib/email.ts runs in stub
# mode — sendBrief() logs "would have emailed X" without making a network
# call. To flip to real delivery:
#   1. Sign up at resend.com (free tier: 100 emails/day, 3k/month)
#   2. Verify your sender domain
#   3. Uncomment + set both keys below
# RESEND_API_KEY=re_...
# LAUNCHPAD_MAIL_FROM=launchpad@yourdomain.com
# LAUNCHPAD_APP_URL=https://launchpad-ten-self.vercel.app
