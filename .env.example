# LLM API Keys (at least one required)
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: OpenClaw integration (for web browsing, tools, multi-channel)
# Install: npm i -g openclaw && openclaw setup
# The app works without OpenClaw (falls back to direct LLM calls)
